<launch>
    <!-- Sim Time -->
    <param name="/use_sim_time" value="true" />

    <!-- Adapter: filter NaN points and remap /rslidar_points -> /velodyne_points -->
    <node pkg="lego_loam_adapter" type="rslidar_filter_node.py" name="rslidar_filter_node" output="screen"/>

    <!-- All frames aligned with identity orientation -->
    <node pkg="tf" type="static_transform_publisher" name="camera_init_to_map"  args="0 0 0 0 0 0 map camera_init 10" />
    <node pkg="tf" type="static_transform_publisher" name="camera_to_base_link" args="0 0 0 0 0 0 camera base_link 10" />

    <!-- LeGO-LOAM -->
    <node pkg="lego_loam" type="imageProjection"    name="imageProjection"    output="screen"/>
    <node pkg="lego_loam" type="featureAssociation" name="featureAssociation" output="screen"/>
    <node pkg="lego_loam" type="mapOptmization"     name="mapOptmization"     output="screen"/>
    <node pkg="lego_loam" type="transformFusion"    name="transformFusion"    output="screen"/>

    <!-- Rviz -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find lego_loam)/launch/test.rviz" />
</launch>
